[mysqld]
# Performance buffer — usar ~50% da memória do container MySQL (limite: 1g)
innodb_buffer_pool_size        = 512M
innodb_buffer_pool_instances   = 2

# Reduz I/O de redo log em workloads de escrita moderada
innodb_log_buffer_size         = 32M

# Flush uma vez por segundo (durabilidade vs performance)
innodb_flush_log_at_trx_commit = 2

# Tabelas temporárias em memória antes de despejar em disco
tmp_table_size                 = 64M
max_heap_table_size            = 64M

# Conexões máximas (alinhado com HikariCP max-pool-size=40 + margem)
max_connections                = 60

# Charset
character-set-server           = utf8mb4
collation-server               = utf8mb4_unicode_ci
